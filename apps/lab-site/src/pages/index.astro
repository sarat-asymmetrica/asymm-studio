---
import LabLayout from '../layouts/LabLayout.astro';
---

<LabLayout title="Lab">
  <section class="hero">
    <div>
      <p class="eyebrow">Generative Aesthetic Engine</p>
      <h1>Asymm Studio</h1>
      <p>Seed quaternions produce deterministic design DNA; bio-resonance surfaces turn local presence into interaction.</p>
      <div class="nav" aria-label="Lab sections">
        <a class="button-link" href="/aesthetic-engine/">Open Engine</a>
        <a class="button-link" href="/bio-resonance/calibration/">Start Ritual</a>
      </div>
    </div>
    <div class="hero-panel">
      <div class="metrics" aria-label="Build status">
        <div class="metric"><strong>8</strong><span>Regions</span></div>
        <div class="metric"><strong>27</strong><span>Catalog Items</span></div>
        <div class="metric"><strong>3</strong><span>Bio Demos</span></div>
        <div class="metric"><strong>55</strong><span>Tests</span></div>
      </div>
      <div class="dna-grid" style="margin-top: 16px">
        <article class="region-card" style="border-color:#b83f31">
          <h3>Wabi-sabi</h3>
          <p>Weathered restraint, asymmetric corners, warm paper.</p>
          <div class="swatches"><span style="background:#f8f5ee"></span><span style="background:#181613"></span><span style="background:#b83f31"></span></div>
        </article>
        <article class="region-card" style="border-color:#006b5f">
          <h3>Ananta-warm</h3>
          <p>Warm infinity, slow motion, devotional gold.</p>
          <div class="swatches"><span style="background:#fff4df"></span><span style="background:#0f1b18"></span><span style="background:#a66f14"></span></div>
        </article>
      </div>
    </div>
  </section>
</LabLayout>
