---
import LabLayout from '../../layouts/LabLayout.astro';
import StressAdaptiveReader from '../../../../../packages/asymm-bio-resonance/components/StressAdaptiveReader.svelte';
---

<LabLayout title="Stress-Adaptive Reader">
  <section class="page-header">
    <p class="eyebrow">Bio-Resonance</p>
    <h1>Reader</h1>
    <p>The reader adapts density, tone, and motion from a local coherence signal. In simulated mode, the HRV trace rises and falls on a visible loop so the adaptation can be inspected immediately.</p>
    <div class="context-links">
      <a class="button-link" href="/bio-resonance/gaze-cursor/">Gaze Cursor</a>
      <a class="button-link" href="/manifesto/">Privacy Contract</a>
    </div>
  </section>
  <div class="demo-panel">
    <StressAdaptiveReader client:load />
  </div>
</LabLayout>
